{
  "name": "langner-browser-extension",
  "version": "0.0.1",
  "private": true,
  "description": "PoC browser extension that captures YouTube video transcripts as Langner story notebooks",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
